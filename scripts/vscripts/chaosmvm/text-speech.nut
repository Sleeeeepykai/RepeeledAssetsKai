function rottenburg_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Welcome mortals, to my magic kingdom!... Which is unaffiliated with any other magic kingdom that may or may not exist.")
}
function rottenburg_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Step right up, and get your tickets from me! For I am the ticket master!")
}
function rottenburg_speech3()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Again, not a term Merasmus officially owns.")
}


function mannhattan_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Greetings mortals and kon'nichiwa! Yes, Merasmus is learning Japanese, in the likely event he will have to beg for his life.")
}
function mannhattan_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Why? Well therein lies a tale of horror! Short version, Merasmus owes $12,000 to the Japanese Mafia!")
}


function mannworks_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Get ready to test your strength!")
}
function mannworks_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Merasmus's dark carnival... is OPEN!")
}


function decoy_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 ATTENTION! Foolish mortals, if you see any Japanese people around, let Merasmus know! Because that is the Japanese Mafia.")
