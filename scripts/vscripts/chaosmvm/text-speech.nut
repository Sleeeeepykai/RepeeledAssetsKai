function bigrock_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Welcome fools, to your doom! It is I, Merasmus!")
}
function bigrock_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Behold, an ancient Sumerian strongman game.")
}
function bigrock_speech3()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 It is old. It is evil. AND IT IS NOT FREE! Have your tickets ready.")
}
function bigrock_speech4()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 You bore Merasmus! Time to make this more interesting...")
}
function bigrock_speech5()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 I see in my crystal ball that you will never win this game!")
}
function bigrock_speech6()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Most villains don't think they're evil. They think they're heroes. Not me! I'm reclaiming it!")
}
function bigrock_speech7()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Evil wizard! I'm rotten to the bone and I don't care who knows it!")
}
function bigrock_jokespawn1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 No, no, no, no, no!")
}
function bigrock_jokespawn2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Why? Why would you do that...?")
}


function coaltown_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 You're starting the Strongmann... FOOLS! I mean, GOOD! Good stuff!")
}
function coaltown_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 I hope you signed your release forms, fools, indemnifying Merasmus in the events of your deaths!")
}
function coaltown_speech3()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Because otherwise, I'm in a lot of trouble. Merasmus has two strikes, I will go to jail... FOREVER!")
}


function redstone_speech1()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Here's a chilling Halloween tale. Once upon a time, an innocent evil wizard named Merasmus bought a circus for $12,000, hoping to flip it and make a fortune!")
}
function redstone_speech2()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 Alas, he did not have $12,000, but do you know who did? The Japanese Mafia!")
}
function redstone_speech3()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 But, due to a language barrier, Merasmus was unclear about the frankly punitive interest rates!")
}
function redstone_speech4()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 WELCOME TO MY FINANCIAL NIGHTMARE, MORTALS!")
}
function redstone_speech5()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 What am I going to do...?")
}