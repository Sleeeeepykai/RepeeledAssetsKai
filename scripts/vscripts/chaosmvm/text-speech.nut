function ghosttown_speech3()
{
    ClientPrint(null, 3 , "\x0743D126[MERASMUS]\x07FFFFFF :\x0799ff99 A harvest moon hangs pendulously in the sky, mortals! That's right, the moon's giving us the green light for harvesting!")
